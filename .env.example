# Copy this file to .env and fill in your values

# Password to access the app
APP_PASSWORD=changeme

# Secret used to sign session cookies — use a long random string
SESSION_SECRET=changeme-secret

# User/group ID the container process runs as (match your host user: run `id` to check)
PUID=1000
PGID=100

# Host path where answers.json, members.json, and media files are stored
ANSWERS_PATH=/path/to/your/data/

# URL of the speaches STT server (OpenAI-compatible /v1/audio/transcriptions endpoint)
# When using the bundled docker-compose, the speaches container is reachable by name
WHISPER_URL=http://speaches:8000

# Whisper model to use — small is fast on GPU, medium/large-v3 for better accuracy
# See https://huggingface.co/Systran for available models
WHISPER_MODEL=Systran/faster-whisper-small

# URL of the speaches TTS server (OpenAI-compatible /v1/audio/speech endpoint)
TTS_URL=http://speaches:8000

# TTS model — speaches uses HuggingFace model IDs, not OpenAI names
# Kokoro-82M is a fast, high-quality English TTS model
TTS_MODEL=speaches-ai/Kokoro-82M-v1.0-ONNX
# Kokoro voice — options: af_heart, af_bella, am_michael, am_adam, bf_emma, bm_george
TTS_VOICE=af_heart
